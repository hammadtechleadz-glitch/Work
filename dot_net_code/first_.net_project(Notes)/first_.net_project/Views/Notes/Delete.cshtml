@model first_.net_project.Models.Note

<h1>Delete Note</h1>

<p>Are you sure you want to delete this note?</p>

<h3>@Model.Title</h3>
<p>@Model.Content</p>

<form asp-action="DeleteConfirmed">

    <input type="hidden" asp-for="Id" />

    <button type="submit">
        Delete
    </button>

</form>