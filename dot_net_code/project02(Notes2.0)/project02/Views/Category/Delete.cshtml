@model project02.Models.Category
@{
    ViewData["Title"] = "Delete Category";
}

<style>
    body {
        font-family: Arial, sans-serif;
        background-color: #f4f6f8;
        margin: 0;
        padding: 0;
    }

    .delete-container {
        width: 500px;
        margin: 80px auto;
        background-color: white;
        padding: 25px;
        border-radius: 8px;
        box-shadow: 0 0 10px rgba(0,0,0,0.1);
        text-align: center;
    }

        .delete-container h2 {
            color: #dc3545;
            margin-bottom: 20px;
        }

    .category-preview {
        background-color: #f8f9fa;
        padding: 15px;
        border-radius: 6px;
        margin-bottom: 20px;
    }

        .category-preview h3 {
            margin: 0;
            color: #333;
        }

    .button-group {
        display: flex;
        gap: 10px;
        justify-content: center;
    }

    .delete-btn,
    .cancel-link {
        padding: 10px 16px;
        border-radius: 5px;
        text-decoration: none;
        border: none;
        font-size: 14px;
        cursor: pointer;
    }

    .delete-btn {
        background-color: #dc3545;
        color: white;
    }

        .delete-btn:hover {
            background-color: #b52a37;
        }

    .cancel-link {
        background-color: #6c757d;
        color: white;
        display: inline-block;
    }

        .cancel-link:hover {
            background-color: #565e64;
        }
</style>

<div class="delete-container">
    <form method="post" asp-controller="Category" asp-action="Delete">
        <input type="hidden" asp-for="id" />

        <h2>Delete Category</h2>
        <p>Are you sure you want to delete this category?</p>

        <div class="category-preview">
            <h3>@Model.category</h3>
        </div>

        <div class="button-group">
            <button type="submit" class="delete-btn">Delete</button>
            <a asp-controller="Category" asp-action="Index" class="cancel-link">Cancel</a>
        </div>
    </form>
</div>