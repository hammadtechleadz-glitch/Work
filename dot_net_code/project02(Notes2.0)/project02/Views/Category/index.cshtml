@model IEnumerable<project02.Models.Category>

@{
    ViewData["Title"] = "Manage Categories";
}

@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager

<style>
    body {
        font-family: Arial, sans-serif;
        background-color: #f4f6f8;
        margin: 0;
        padding: 0;
    }

    .page-container {
        width: 900px;
        margin: 40px auto;
    }

    .top-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        flex-wrap: wrap;
        gap: 10px;
    }

    .logout-form {
        margin: 0;
    }

        .logout-form button {
            padding: 10px 14px;
            background-color: #0078d4;
            color: white;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-size: 14px;
        }

            .logout-form button:hover {
                background-color: #005fa3;
            }

    .back-link {
        text-decoration: none;
        color: #0078d4;
        font-weight: bold;
    }

        .back-link:hover {
            text-decoration: underline;
        }

    .header-card {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        background-color: white;
        padding: 20px;
        border-radius: 8px;
        box-shadow: 0 0 10px rgba(0,0,0,0.08);
    }

        .header-card h1 {
            margin: 0;
        }

    .add-link {
        text-decoration: none;
        background-color: #28a745;
        color: white;
        padding: 10px 14px;
        border-radius: 5px;
        font-size: 14px;
    }

        .add-link:hover {
            background-color: #218838;
        }

    .category-list {
        display: flex;
        flex-direction: column;
        gap: 15px;
    }

    .category-card {
        background-color: white;
        padding: 18px;
        border-radius: 8px;
        box-shadow: 0 0 10px rgba(0,0,0,0.08);
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 10px;
    }

    .category-name {
        font-size: 18px;
        font-weight: bold;
        color: #333;
    }

    .category-actions a {
        text-decoration: none;
        padding: 8px 12px;
        border-radius: 5px;
        color: white;
        margin-left: 8px;
        font-size: 14px;
        display: inline-block;
    }

    .edit-btn {
        background-color: #0078d4;
    }

        .edit-btn:hover {
            background-color: #005fa3;
        }

    .delete-btn {
        background-color: #dc3545;
    }

        .delete-btn:hover {
            background-color: #b52a37;
        }

    .empty-message {
        background-color: white;
        padding: 20px;
        border-radius: 8px;
        text-align: center;
        box-shadow: 0 0 10px rgba(0,0,0,0.08);
    }
</style>

<div class="page-container">

    <div class="top-bar">
        @if (SignInManager.IsSignedIn(User))
        {
            <form asp-action="Logout" asp-controller="Account" method="post" class="logout-form">
                <button type="submit">Logout</button>
            </form>
        }

        <a asp-controller="Notes" asp-action="Index" class="back-link">Back to Notes</a>
    </div>

    <div class="header-card">
        <h1>Manage Categories</h1>
        <a asp-controller="Category" asp-action="Create" class="add-link">Add Category</a>
    </div>

    @if (Model.Any())
    {
        <div class="category-list">
            @foreach (var item in Model)
            {
                <div class="category-card">
                    <div class="category-name">@item.category</div>

                    <div class="category-actions">
                        <a asp-controller="Category" asp-action="Edit" asp-route-id="@item.id" class="edit-btn">Edit</a>
                        <a asp-controller="Category" asp-action="Delete" asp-route-id="@item.id" class="delete-btn">Delete</a>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-message">
            <p>No Categories Yet</p>
        </div>
    }

</div>